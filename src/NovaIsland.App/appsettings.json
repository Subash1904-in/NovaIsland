{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Stability": {
    "HeartbeatIntervalMs": 500,
    "HeartbeatPipeName": "NovaIsland_Heartbeat",
    "MissedHeartbeatsForRestart": 4,
    "WorkingSetCheckIntervalSeconds": 30,
    "IdleTrimDebounceSeconds": 60,
    "WorkingSetWarnThresholdMb": 35,
    "HandleCountWarnThreshold": 500,
    "CrashLoopThreshold": 3,
    "CrashLoopWindowMinutes": 5,
    "ModuleMaxRetries": 5
  },
  "Island": {
    "Stiffness": 300.0,
    "Damping": 0,
    "ReducedMotion": false,
    "InitialState": "Compact",
    "CompactWidth": 220,
    "CompactHeight": 40,
    "ExpandedWidth": 400,
    "ExpandedHeight": 320,
    "MinimalWidth": 120,
    "MinimalHeight": 8,
    "AlertWidth": 300,
    "AlertHeight": 60
  }
}
