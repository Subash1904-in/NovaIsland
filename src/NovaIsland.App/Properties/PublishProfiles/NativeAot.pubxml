<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <PublishDir>bin\Release\net9.0-windows10.0.22621.0\win-x64\publish\</PublishDir>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishAot>true</PublishAot>
    <PublishTrimmed>true</PublishTrimmed>
    <!-- Invariant globalization reduces binary size; Nova Island is Windows-only
         and uses OS APIs for locale-specific display. -->
    <InvariantGlobalization>true</InvariantGlobalization>
    <!-- Produce a single file for clean deployment -->
    <PublishSingleFile>false</PublishSingleFile>
    <!-- Strip debug symbols from the published output -->
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <!-- Optimize for speed over size — critical for 120 FPS target -->
    <OptimizationPreference>Speed</OptimizationPreference>
    <!-- ILC: enable full link-time optimization for best codegen -->
    <IlcOptimizationPreference>Speed</IlcOptimizationPreference>
  </PropertyGroup>
</Project>
