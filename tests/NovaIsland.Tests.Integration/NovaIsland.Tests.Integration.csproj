    </PackageReference>
    <PackageReference Include="FluentAssertions" Version="7.1.0" />
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="9.0.0" />
    <PackageReference Include="coverlet.collector" Version="6.0.3">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\NovaIsland.Infrastructure\NovaIsland.Infrastructure.csproj" />
    <ProjectReference Include="..\..\src\NovaIsland.Application\NovaIsland.Application.csproj" />
    <ProjectReference Include="..\..\src\NovaIsland.Watchdog\NovaIsland.Watchdog.csproj" />
    <ProjectReference Include="..\..\src\NovaIsland.Plugins.Host\NovaIsland.Plugins.Host.csproj" />
  </ItemGroup>

</Project>
