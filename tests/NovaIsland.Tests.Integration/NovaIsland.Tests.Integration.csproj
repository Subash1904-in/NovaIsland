<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>NovaIsland.Tests.Integration</RootNamespace>
    <AssemblyName>NovaIsland.Tests.Integration</AssemblyName>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <Description>Integration tests for Nova Island infrastructure, stability, and host bootstrapping.</Description>
